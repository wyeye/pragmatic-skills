{
  "schema": "psp.host-adapters/v2",
  "version": "2.0.2",
  "default": "auto",
  "hosts": {
    "agents": {
      "always_in_minimal": true,
      "files": [
        "AGENTS.md",
        ".agents/skills/using-pragmatic-skills/SKILL.md"
      ],
      "notes": "Common AGENTS.md plus an Agent Skills entry adapter."
    },
    "codex": {
      "uses": [
        "agents"
      ],
      "notes": "Uses AGENTS.md and .agents/skills discovery."
    },
    "claude": {
      "files": [
        "CLAUDE.md",
        ".claude/skills/psp-claude-entry/SKILL.md"
      ],
      "notes": "Uses a unique Claude entry name to avoid duplicate discovery."
    },
    "opencode": {
      "files": [
        ".opencode/commands/psp.md"
      ],
      "uses": [
        "agents"
      ],
      "notes": "Uses .agents/skills for native discovery; command is optional convenience."
    },
    "hermes": {
      "uses": [
        "agents"
      ]
    },
    "gemini": {
      "files": [
        "GEMINI.md"
      ],
      "uses": [
        "agents"
      ]
    },
    "copilot": {
      "files": [
        ".github/copilot-instructions.md"
      ],
      "uses": [
        "agents"
      ]
    },
    "cursor": {
      "files": [
        ".cursor/rules/pragmatic-skills-pack.mdc"
      ],
      "uses": [
        "agents"
      ]
    }
  }
}
