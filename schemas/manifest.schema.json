{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/psp/manifest.schema.json",
  "title": "Pragmatic Skills Pack manifest",
  "type": "object",
  "required": [
    "schema",
    "package_id",
    "name",
    "version",
    "generated_at",
    "entry_skill",
    "primary_modes",
    "payload_roots",
    "skills"
  ],
  "properties": {
    "schema": {"const": "psp.manifest/v2"},
    "package_id": {"const": "pragmatic-skills-pack"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"},
    "generated_at": {"type": "string", "minLength": 1},
    "entry_skill": {"type": "string", "minLength": 1},
    "primary_modes": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "payload_roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "sidecar", "kind", "version", "entry", "loads", "sha256", "sidecar_sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sidecar": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "entry": {"type": "boolean"},
          "loads": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "sidecar_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
