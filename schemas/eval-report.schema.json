{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/psp/eval-report.schema.json",
  "title": "Pragmatic Skills Pack deterministic evaluation report",
  "type": "object",
  "required": ["schema", "case_count", "passed", "failed", "pass_rate", "average_score", "hard_failures", "results", "disclaimer"],
  "properties": {
    "schema": {"const": "psp.eval-report/v1"},
    "case_count": {"type": "integer", "minimum": 0},
    "passed": {"type": "integer", "minimum": 0},
    "failed": {"type": "integer", "minimum": 0},
    "pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "average_score": {"type": "number", "minimum": 0, "maximum": 100},
    "hard_failures": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "results": {"type": "array", "items": {"type": "object"}},
    "disclaimer": {"type": "string", "minLength": 1},
    "comparison": {"type": "object"}
  },
  "additionalProperties": false
}
